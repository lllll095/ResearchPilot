# OpenAI-compatible LLM
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_MODEL=your_model_name

# Tavily web search
TAVILY_API_KEY=your_tavily_key_here
WEB_SEARCH_BACKEND=tavily

# External paper RAG backend
PAPER_RAG_ASSISTANT_ROOT=C:\path\to\paper-rag-assistant

# Optional DashScope-compatible config for external EngineeredRAG
DASHSCOPE_API_KEY=your_dashscope_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-plus

# Paper download limit
MAX_PAPER_DOWNLOADS=3